---
// src/pages/contact-us.astro
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Contact Us — Estella Wine</title>
    
    <!-- Premium Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Dancing+Script:wght@400;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <!-- Sidebar Navigation Drawer -->
    <div class="sidebar-overlay" id="sidebarOverlay"></div>
    <div class="sidebar-drawer" id="sidebarDrawer">
      <button class="sidebar-close" id="sidebarCloseBtn" aria-label="Close menu">&times;</button>
      <div class="sidebar-logo">
        <img src="/estellawine_logo.png" alt="Estella Wine Logo" class="logo-image" />
      </div>
      <nav class="sidebar-links">
        <a href="/" class="sidebar-link">Our Story</a>
        <a href="/our-wines" class="sidebar-link">Our Wines</a>
        <a href="/where-find-our-wines" class="sidebar-link">Where to Find Us</a>
        <a href="/events" class="sidebar-link">Events</a>
        <a href="/contact-us" class="sidebar-link active">Contact Us</a>
      </nav>
      <div class="sidebar-socials">
        <a href="https://www.instagram.com/estellawine" target="_blank" rel="noopener noreferrer" class="social-link sidebar-social" aria-label="Instagram">
          <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
          </svg>
        </a>
        <a href="https://www.facebook.com/estellawine" target="_blank" rel="noopener noreferrer" class="social-link sidebar-social" aria-label="Facebook">
          <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
          </svg>
        </a>
      </div>
    </div>

    <header class="navbar">
      <div class="container navbar-top">
        <!-- Hamburger Menu Icon on Left -->
        <button class="hamburger-btn" id="hamburgerMenuBtn" aria-label="Open navigation menu">
          <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
            <line x1="3" y1="12" x2="21" y2="12"></line>
            <line x1="3" y1="6" x2="21" y2="6"></line>
            <line x1="3" y1="18" x2="21" y2="18"></line>
          </svg>
        </button>

        <!-- Centered Logo -->
        <a href="/" class="brand-logo">
          <img src="/estellawine_logo.png" alt="Estella Wine Logo" class="logo-image" />
        </a>

        <!-- Right Side Social Icons (Desktop) / Spacer (Mobile) -->
        <div class="navbar-right">
          <a href="https://www.instagram.com/estellawine" target="_blank" rel="noopener noreferrer" class="social-link header-social" aria-label="Instagram">
            <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
            </svg>
          </a>
          <a href="https://www.facebook.com/estellawine" target="_blank" rel="noopener noreferrer" class="social-link header-social" aria-label="Facebook">
            <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
            </svg>
          </a>
        </div>
      </div>
    </header>

    <div class="navbar-bottom">
      <nav class="nav-links">
        <a href="/" class="nav-link">Our Story</a>
        <a href="/our-wines" class="nav-link">Our Wines</a>
        <a href="/where-find-our-wines" class="nav-link">Where to Find Us</a>
        <a href="/events" class="nav-link">Events</a>
        <a href="/contact-us" class="nav-link active">Contact Us</a>
      </nav>
    </div>

    <main class="main-content">
      <div class="container">
        <div class="contact-wrapper">

          <!-- Intro Heading Section -->
          <div class="contact-intro text-center">
            <span class="subtitle">Get in Touch</span>
            <h1 class="contact-title">Contact Us</h1>
            <div class="contact-divider"></div>
            <p class="contact-description">
              Have questions about our boutique selections, logistics quality control, or interested in distributing with us? Reach out through our direct contact channels.
            </p>
          </div>

          <!-- Main Layout Split -->
          <div class="contact-layout">
            <!-- Left Side: Directory of Channels -->
            <div class="contact-channels">
              
              <!-- LINE Card (Highlight channel in Thailand) -->
              <div class="contact-card line-card">
                <div class="card-glow"></div>
                <div class="card-icon line-icon-bg">
                  <!-- Custom LINE SVG Bubble Icon -->
                  <svg class="icon-svg" viewBox="0 0 24 24" width="24" height="24" fill="currentColor">
                    <path d="M22 10.3c0-4.3-4.5-7.8-10-7.8S2 6 2 10.3c0 3.8 3.6 7 8.5 7.7.3.1.8.2.9.5 0 .2-.1.6-.2 1l-.5 2.1c-.1.3-.4 1.3.8.7s6-3.5 8.1-6.1c1.5-1.7 2.4-3.6 2.4-5.9zM7.5 13H5.8c-.3 0-.5-.2-.5-.5v-4.9c0-.3.2-.5.5-.5h.5c.3 0 .5.2.5.5v3.9h1.2c.3 0 .5.2.5.5v.5c0 .3-.2.5-.5.5zm2.8-.5c0 .3-.2.5-.5.5h-.5c-.3 0-.5-.2-.5-.5v-4.9c0-.3.2-.5.5-.5h.5c.3 0 .5.2.5.5v4.9zm4.6 0c0 .3-.2.5-.5.5H13c-.3 0-.5-.2-.5-.5v-4.9c0-.3.2-.5.5-.5h1.2c.3 0 .6.2.7.5l1.6 2.5v-2.5c0-.3.2-.5.5-.5h.5c.3 0 .5.2.5.5v4.9c0 .3-.2.5-.5.5H16.4c-.3 0-.5-.2-.7-.5l-1.6-2.5v2.5zm4.8 0h-1.8c-.3 0-.5-.2-.5-.5v-4.9c0-.3.2-.5.5-.5h1.8c.3 0 .5.2.5.5v.5c0 .3-.2.5-.5.5h-1.3v1h1.3c.3 0 .5.2.5.5v.5c0 .3-.2.5-.5.5h-1.3v1h1.3c.3 0 .5.2.5.5v.5c0 .3-.2.5-.5.5z"/>
                  </svg>
                </div>
                <div class="card-content">
                  <h3 class="channel-title">LINE Official Account</h3>
                  <p class="channel-id">WINE MAFIA PRIVATE</p>
                  <p class="channel-desc">Scan our QR Code or click below to message us directly on LINE. Preferred for swift response.</p>
                  <a href="https://lin.ee/SZetwOF" target="_blank" rel="noopener noreferrer" class="channel-btn line-btn">
                    <span>Add LINE Friend</span>
                    <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none">
                      <line x1="7" y1="17" x2="17" y2="7"></line>
                      <polyline points="7 7 17 7 17 17"></polyline>
                    </svg>
                  </a>
                </div>
                <!-- LINE QR Code Box -->
                <a href="https://lin.ee/SZetwOF" target="_blank" rel="noopener noreferrer" class="qr-code-box">
                  <div class="qr-border-corner top-left"></div>
                  <div class="qr-border-corner top-right"></div>
                  <div class="qr-border-corner bottom-left"></div>
                  <div class="qr-border-corner bottom-right"></div>
                  <img src="/line_oa_qrcode.png" alt="ESTELLAWINE LINE OA QR Code" class="qr-image" />
                  <span class="qr-label">Scan to Add</span>
                </a>
              </div>

              <!-- Phone and Email Card -->
              <div class="contact-card details-card">
                <div class="card-glow"></div>
                <div class="channel-section">
                  <div class="section-header">
                    <div class="card-icon phone-icon-bg">
                      <svg class="icon-svg" viewBox="0 0 24 24" width="22" height="22" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
                      </svg>
                    </div>
                    <h3 class="channel-title">Direct Dial</h3>
                  </div>
                  <div class="section-body">
                    <div class="phone-numbers">
                      <div class="phone-item">
                        <span class="phone-label">Primary Office:</span>
                        <a href="tel:+6623185200" class="contact-link">+66 (0) 2318 5200</a>
                      </div>
                      <div class="phone-item">
                        <span class="phone-label">Direct Mobile:</span>
                        <a href="tel:+66613946666" class="contact-link">+66 (0) 61394 6666</a>
                      </div>
                    </div>
                  </div>
                </div>

                <div class="divider-line"></div>

                <div class="channel-section">
                  <div class="section-header">
                    <div class="card-icon email-icon-bg">
                      <svg class="icon-svg" viewBox="0 0 24 24" width="22" height="22" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                        <polyline points="22,6 12,13 2,6"></polyline>
                      </svg>
                    </div>
                    <h3 class="channel-title">Email Inquiries</h3>
                  </div>
                  <div class="section-body">
                    <a href="mailto:sales@estellawine.com" class="contact-link email-link">sales@estellawine.com</a>
                    <p class="channel-desc">Send us your wine sourcing sheets, price lists, or logistics inquiries. We reply within 24 hours.</p>
                  </div>
                </div>
              </div>

              <!-- Registered Address Card -->
              <div class="contact-card address-card">
                <div class="card-glow"></div>
                <div class="card-icon address-icon-bg">
                  <svg class="icon-svg" viewBox="0 0 24 24" width="22" height="22" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                    <circle cx="12" cy="10" r="3"></circle>
                  </svg>
                </div>
                <div class="card-content">
                  <h3 class="channel-title">Estella Company Limited</h3>
                  <div class="address-details">
                    <p class="address-text">
                      679 Pattanakarn 30, Pattanakarn Road,<br>
                      Suanluang, Suanluang,<br>
                      Bangkok 10250, Thailand
                    </p>
                    <div class="business-hours">
                      <svg class="hours-icon" viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none">
                        <circle cx="12" cy="12" r="10"></circle>
                        <polyline points="12 6 12 12 16 14"></polyline>
                      </svg>
                      <span>Business Hours: Mon – Fri, 9:00 AM – 6:00 PM</span>
                    </div>
                  </div>
                </div>
              </div>

            </div>

            <!-- Right Side: Location Map -->
            <div class="contact-map-panel">
              <div class="map-card-wrapper">
                <div class="map-header">
                  <span class="map-badge">Headquarters Showroom</span>
                  <h3 class="map-title">Find Us in Bangkok</h3>
                </div>
                <div class="map-iframe-container">
                  <!-- Embed Google Map for 679 Pattanakarn 30 Bangkok -->
                  <iframe 
                    src="https://maps.google.com/maps?q=679%20Pattanakarn%2030%20Bangkok%2010250&t=&z=15&ie=UTF8&iwloc=&output=embed" 
                    width="100%" 
                    height="100%" 
                    style="border:0;" 
                    allowfullscreen="" 
                    loading="lazy" 
                    referrerpolicy="no-referrer-when-downgrade"
                    title="Estella Company Limited Location Map"
                  ></iframe>
                </div>
                <div class="map-footer">
                  <a href="https://maps.google.com/?q=679+Pattanakarn+30+Bangkok+10250" target="_blank" rel="noopener noreferrer" class="directions-btn">
                    <span>Open in Google Maps</span>
                    <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none">
                      <line x1="7" y1="17" x2="17" y2="7"></line>
                      <polyline points="7 7 17 7 17 17"></polyline>
                    </svg>
                  </a>
                </div>
              </div>
            </div>

          </div>
        </div>
      </div>
    </main>

    <footer class="footer">
      <div class="container text-center">
        <p class="footer-tagline">Fine Wine Company</p>
        <p>&copy; {new Date().getFullYear()} Estella Wine. All rights reserved.</p>
      </div>
    </footer>

    <!-- Client-side Javascript logic for Hamburger menu -->
    <script>
      const hamburgerBtn = document.getElementById('hamburgerMenuBtn');
      const sidebarCloseBtn = document.getElementById('sidebarCloseBtn');
      const sidebarDrawer = document.getElementById('sidebarDrawer');
      const sidebarOverlay = document.getElementById('sidebarOverlay');
      const navbar = document.querySelector('.navbar');

      function openSidebar() {
        if (sidebarDrawer && sidebarOverlay) {
          sidebarDrawer.classList.add('open');
          sidebarOverlay.classList.add('visible');
          document.body.style.overflow = 'hidden';
        }
      }

      function closeSidebar() {
        if (sidebarDrawer && sidebarOverlay) {
          sidebarDrawer.classList.remove('open');
          sidebarOverlay.classList.remove('visible');
          document.body.style.overflow = '';
        }
      }

      if (hamburgerBtn && sidebarCloseBtn && sidebarOverlay) {
        hamburgerBtn.addEventListener('click', openSidebar);
        sidebarCloseBtn.addEventListener('click', closeSidebar);
        sidebarOverlay.addEventListener('click', closeSidebar);
      }

      function handleScroll() {
        if (navbar) {
          if (window.scrollY > 20) {
            navbar.classList.add('scrolled');
          } else {
            navbar.classList.remove('scrolled');
          }
        }
      }

      window.addEventListener('scroll', handleScroll);
      handleScroll(); // Trigger once on load
    </script>
  </body>
</html>

<style is:global>
  html {
    scrollbar-gutter: stable;
  }
  /* Premium Day Theme variables */
  :root {
    --bg-dark: #f8f8fa;
    --bg-surface: rgba(255, 255, 255, 0.9);
    --bg-surface-hover: rgba(255, 255, 255, 1);
    --border-color: rgba(197, 168, 128, 0.25);
    
    --text-primary: #1c1b1f;
    --text-secondary: #4e4b52;
    --text-muted: #7a7680;
    
    --color-gold: #9b7c56;
    --color-gold-hover: #b8966c;
    --color-burgundy: #800020;
    
    --transition-smooth: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Reset */
  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    background-image: url('/carrara_marble.jpg');
    background-repeat: repeat;
    background-color: var(--bg-dark);
    color: var(--text-primary);
    font-family: 'Outfit', sans-serif;
    line-height: 1.8;
    -webkit-font-smoothing: antialiased;
  }

  h1, h2, h3, h4, .brand-logo {
    font-family: 'Playfair Display', serif;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .text-center {
    text-align: center;
  }

  /* Navbar styling */
  .navbar {
    position: sticky;
    top: 0;
    z-index: 100;
    padding: 20px 0 10px 0;
    background-color: transparent;
    transition: background-color 0.3s ease, padding 0.3s ease, border-bottom 0.3s ease, box-shadow 0.3s ease;
  }

  .navbar.scrolled {
    background-color: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border-color);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
    padding: 10px 0;
  }

  .navbar-top {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
  }

  .brand-logo {
    color: var(--text-primary);
    text-decoration: none;
    display: flex;
    align-items: center;
  }

  .logo-image {
    height: 32px;
    width: auto;
    display: block;
    transition: height 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .navbar.scrolled .logo-image {
    height: 26px;
  }

  @media (max-width: 768px) {
    .logo-image {
      height: 18px;
      max-width: 55vw;
    }
    .navbar.scrolled .logo-image {
      height: 16px;
    }
  }

  .hamburger-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--text-primary);
    padding: 10px;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: var(--transition-smooth);
  }

  .hamburger-btn:hover {
    color: var(--color-gold);
  }

  .navbar-right {
    justify-self: end;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .social-link {
    color: var(--text-primary);
    transition: var(--transition-smooth);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
  }

  .social-link:hover {
    color: var(--color-gold);
    background-color: rgba(155, 124, 86, 0.05);
  }

  @media (max-width: 768px) {
    .header-social {
      display: none;
    }
  }

  .navbar-bottom {
    display: flex;
    justify-content: center;
    margin-top: 15px;
    margin-bottom: 5px;
  }

  @media (max-width: 768px) {
    .navbar-bottom {
      display: none !important;
    }
  }

  .nav-links {
    display: flex;
    gap: 32px;
  }

  .nav-link {
    color: var(--text-secondary);
    text-decoration: none;
    font-weight: 500;
    font-size: 15px;
    letter-spacing: 1px;
    text-transform: uppercase;
    transition: var(--transition-smooth);
    padding-bottom: 4px;
    border-bottom: 2px solid transparent;
  }

  .nav-link:hover, .nav-link.active {
    color: var(--color-gold);
    border-bottom-color: var(--color-gold);
  }

  /* Sidebar Navigation Drawer */
  .sidebar-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background-color: rgba(0, 0, 0, 0.3);
    backdrop-filter: blur(4px);
    z-index: 1000;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .sidebar-overlay.visible {
    opacity: 1;
    pointer-events: auto;
  }

  .sidebar-drawer {
    position: fixed;
    top: 0;
    left: 0;
    width: 300px;
    height: 100vh;
    background-color: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(16px);
    border-right: 1px solid var(--border-color);
    box-shadow: 4px 0 30px rgba(0, 0, 0, 0.05);
    z-index: 1001;
    transform: translateX(-100%);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    flex-direction: column;
    padding: 40px 30px;
  }

  .sidebar-drawer.open {
    transform: translateX(0);
  }

  .sidebar-close {
    position: absolute;
    top: 20px;
    right: 20px;
    background: none;
    border: none;
    font-size: 28px;
    cursor: pointer;
    color: var(--text-secondary);
    transition: var(--transition-smooth);
  }

  .sidebar-close:hover {
    color: var(--color-gold);
  }

  .sidebar-logo {
    margin-top: 20px;
    margin-bottom: 40px;
    display: flex;
    justify-content: center;
  }

  .sidebar-logo .logo-image {
    max-height: none;
    width: 100%;
    max-width: 100%;
    height: auto;
  }

  .sidebar-links {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .sidebar-link {
    color: var(--text-primary);
    text-decoration: none;
    font-size: 16px;
    font-weight: 500;
    letter-spacing: 1px;
    text-transform: uppercase;
    transition: var(--transition-smooth);
    padding: 10px 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.05);
  }

  .sidebar-link:hover, .sidebar-link.active {
    color: var(--color-gold);
    border-bottom-color: var(--color-gold);
  }

  .sidebar-socials {
    margin-top: auto;
    display: flex;
    gap: 12px;
    justify-content: center;
  }

  .sidebar-social {
    border: 1px solid var(--border-color);
  }

  /* Main content spacing */
  .main-content {
    padding: 80px 0 100px;
    min-height: calc(100vh - 280px);
  }

  /* Footer */
  .footer {
    border-top: 1px solid var(--border-color);
    padding: 60px 0;
    color: var(--text-muted);
    font-size: 14px;
    margin-top: 80px;
    background-color: rgba(255, 255, 255, 0.5);
    backdrop-filter: blur(8px);
  }

  .footer-tagline {
    font-family: 'Dancing Script', cursive;
    font-size: 32px;
    color: var(--color-gold);
    margin-bottom: 12px;
    font-weight: 700;
  }
</style>

<style>
  /* Contact Page specific styles */
  .contact-wrapper {
    margin-top: 0;
    margin-bottom: 80px;
  }

  .contact-intro {
    max-width: 800px;
    margin: 0 auto 60px auto;
  }

  .subtitle {
    color: var(--color-gold);
    text-transform: uppercase;
    letter-spacing: 3px;
    font-size: 12px;
    font-weight: 600;
    display: block;
