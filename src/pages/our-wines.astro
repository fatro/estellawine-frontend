import { createDirectus, rest, readItems } from '@directus/sdk';
import fs from 'fs';
import path from 'path';

// Initialize Directus SDK client
const client = createDirectus('https://cms.estellawine.com').with(rest());

// Load combined Europe SVG map
const europeSvgPath = path.join(process.cwd(), 'public/combined-europe.svg');
const europeSvg = fs.readFileSync(europeSvgPath, 'utf8');

let wines = [];
let error = null;

try {
  wines = await client.request(
    readItems('wines', {
      filter: {
        brand: {
          _eq: 'Estella Wine',
        },
      },
    })
  );
} catch (e) {
  console.error('Error fetching wines from Directus:', e);
  error = e.message;
}

// Calculate counts dynamically from CMS catalog
const counts = {
  regions: {},
  countries: {}
};

wines.forEach(wine => {
  const loc = getWineLocation(wine.region);
  if (loc.region) {
    counts.regions[loc.region] = (counts.regions[loc.region] || 0) + 1;
  } else if (wine.region) {
    const norm = wine.region.trim();
    counts.regions[norm] = (counts.regions[norm] || 0) + 1;
  }
  if (loc.country) {
    counts.countries[loc.country] = (counts.countries[loc.country] || 0) + 1;
  }
});

// Map regions to parent categories for filtering on the map
function getWineLocation(region) {
  const normalized = (region || '').trim();
  
  if (['Piedmont', 'Barolo'].includes(normalized)) {
    return { country: 'Italy', region: 'Piedmont' };
  }
  if (['Tuscany', 'Brunello di Montalcino'].includes(normalized)) {
    return { country: 'Italy', region: 'Tuscany' };
  }
  if (['Veneto'].includes(normalized)) {
    return { country: 'Italy', region: 'Veneto' };
  }
  if (['Friuli Venezia Giulia'].includes(normalized)) {
    return { country: 'Italy', region: 'Friuli Venezia Giulia' };
  }
  if (['Sicily'].includes(normalized)) {
    return { country: 'Italy', region: 'Sicily' };
  }
  if (['Italy'].includes(normalized)) {
    return { country: 'Italy', region: 'Italy' };
  }

  if (['Loire', 'Vouvray', 'Saumur'].includes(normalized)) {
    return { country: 'France', region: 'Loire' };
  }
  if (['Bordeaux', 'Pomerol', 'Saint Émilion'].includes(normalized)) {
    return { country: 'France', region: 'Bordeaux' };
  }
  if (['Champagne'].includes(normalized)) {
    return { country: 'France', region: 'Champagne' };
  }
  if (['Alsace'].includes(normalized)) {
    return { country: 'France', region: 'Alsace' };
  }
  if (['France', 'Roussillon'].includes(normalized)) {
    return { country: 'France', region: 'France' };
  }

  if (['Spain', 'Austria', 'Germany', 'Chile'].includes(normalized)) {
    return { country: normalized, region: normalized };
  }

  return { country: 'Unknown', region: normalized };
}

function formatWineRegion(region) {
  const normalized = (region || '').trim();
  if (!normalized) return 'Unknown Region';
  
  const loc = getWineLocation(normalized);
  
  const flags = {
    'Italy': '🇮🇹',
    'France': '🇫🇷',
    'Spain': '🇪🇸',
    'Austria': '🇦🇹',
    'Germany': '🇩🇪',
    'Chile': '🇨🇱'
  };
  
  const flag = flags[loc.country] || '';
  const flagPrefix = flag ? `${flag} ` : '';
  
  if (loc.region && loc.region !== normalized && loc.region !== loc.country) {
    return `${flagPrefix}${loc.region} — ${normalized}`;
  }
  
  return `${flagPrefix}${normalized}`;
}

function parseGrapeVarieties(varieties) {
  if (!varieties || !Array.isArray(varieties)) return [];
  
  let result = [];
  varieties.forEach(item => {
    if (typeof item !== 'string') return;
    
    // Split combined strings like "60% Zweigelt 35% Blaufrankisch" into individual elements
    const regex = /(\d+%\s*[^0-9%/\-]+)/g;
    const matchesList = item.match(regex);
    if (matchesList && matchesList.length > 1) {
      matchesList.forEach(m => {
        let cleaned = m.trim().replace(/^[\s\/|\-]+|[\s\/|\-]+$/g, '').trim();
        if (cleaned) result.push(cleaned);
      });
    } else {
      result.push(item);
    }
  });
  return result;
}
