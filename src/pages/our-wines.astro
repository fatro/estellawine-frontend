    </main>

    <footer class="footer">
      <div class="container text-center">
        <p class="footer-tagline">Fine Wine Company</p>
        <p>&copy; {new Date().getFullYear()} Estella Wine. All rights reserved.</p>
      </div>
    </footer>

    <script>
      const hamburgerBtn = document.getElementById('hamburgerMenuBtn');
      const sidebarCloseBtn = document.getElementById('sidebarCloseBtn');
      const sidebarDrawer = document.getElementById('sidebarDrawer');
      const sidebarOverlay = document.getElementById('sidebarOverlay');
      const navbar = document.querySelector('.navbar');

      function openSidebar() {
        if (sidebarDrawer && sidebarOverlay) {
          sidebarDrawer.classList.add('open');
          sidebarOverlay.classList.add('visible');
          document.body.style.overflow = 'hidden';
        }
      }

      function closeSidebar() {
        if (sidebarDrawer && sidebarOverlay) {
          sidebarDrawer.classList.remove('open');
          sidebarOverlay.classList.remove('visible');
          document.body.style.overflow = '';
        }
      }

      if (hamburgerBtn && sidebarCloseBtn && sidebarOverlay) {
        hamburgerBtn.addEventListener('click', openSidebar);
        sidebarCloseBtn.addEventListener('click', closeSidebar);
        sidebarOverlay.addEventListener('click', closeSidebar);
      }

      function handleScroll() {
        if (navbar) {
          if (window.scrollY > 20) {
            navbar.classList.add('scrolled');
          } else {
            navbar.classList.remove('scrolled');
          }
        }
      }

      window.addEventListener('scroll', handleScroll);
      // Run once on load to set initial state
      handleScroll();

      // Catalog Filtering Logic
      const hotspots = document.querySelectorAll('.hotspot, .mobile-filter-pill, .extra-filter-pill');
      const mapRegions = document.querySelectorAll('.map-region-path, .map-country-group');
      
      // Deactivate map regions that have no corresponding active hotspots (0 wines in stock)
      mapRegions.forEach(el => {
        const region = el.getAttribute('data-filter-region');
        const country = el.getAttribute('data-filter-country');
        
        let hasHotspot = false;
        if (region) {
          hasHotspot = document.querySelector(`.hotspot[data-filter-region="${region}"]`) !== null;
        } else if (country) {
          // A country group is active if the country itself has an active hotspot, 
          // or if ANY of its nested regions have an active hotspot.
          const countryHasHotspot = document.querySelector(`.hotspot[data-filter-country="${country}"]:not(.inactive)`) !== null;
          let anyRegionActive = false;
          if (country === 'France') {
            const franceRegions = ['Champagne', 'Alsace', 'Loire', 'Bordeaux'];
            anyRegionActive = franceRegions.some(r => document.querySelector(`.hotspot[data-filter-region="${r}"]`) !== null);
          } else if (country === 'Italy') {
            const italyRegions = ['Piedmont', 'Veneto', 'Friuli Venezia Giulia', 'Tuscany', 'Sicily'];
            anyRegionActive = italyRegions.some(r => document.querySelector(`.hotspot[data-filter-region="${r}"]`) !== null);
          }
          hasHotspot = countryHasHotspot || anyRegionActive;
        }
        
        if (!hasHotspot) {
          // Disable pointer events and interactive cursor
          el.style.pointerEvents = 'none';
          el.style.cursor = 'default';
          el.classList.remove('map-region-path');
          
          // Mute colors visually (faint gray outlines)
          const paths = el.tagName === 'path' ? [el] : el.querySelectorAll('path');
          paths.forEach(p => {
            p.style.fill = 'rgba(155, 124, 86, 0.008)';
            p.style.stroke = 'rgba(155, 124, 86, 0.08)';
            p.classList.remove('map-country-fill', 'map-region-line');
          });
        }
      });

      const wineCards = document.querySelectorAll('.wine-card');
      const activeFilterBar = document.getElementById('activeFilterBar');
      const activeFilterLabel = document.getElementById('activeFilterLabel');
      const activeFilterCount = document.getElementById('activeFilterCount');
      const clearFilterBtn = document.getElementById('clearFilterBtn');

      let activeRegion = null;
      let activeCountry = null;

      function filterCatalog() {
        let visibleCount = 0;
        
        wineCards.forEach(card => {
          const region = card.getAttribute('data-region');
          const country = card.getAttribute('data-country');
          
          let match = true;
          if (activeRegion && region !== activeRegion) {
            match = false;
          } else if (activeCountry && country !== activeCountry) {
            match = false;
          }
          
          if (match) {
            (card as HTMLElement).style.display = '';
            // Micro-delay for smooth CSS transitions
            setTimeout(() => {
              (card as HTMLElement).style.opacity = '1';
              (card as HTMLElement).style.transform = 'translateY(0) scale(1)';
            }, 50);
            visibleCount++;
          } else {
            (card as HTMLElement).style.opacity = '0';
            (card as HTMLElement).style.transform = 'translateY(10px) scale(0.98)';
            setTimeout(() => {
              (card as HTMLElement).style.display = 'none';
            }, 300);
          }
        });

        // Update visual display of filter bar
        if (activeFilterBar && activeFilterLabel && activeFilterCount) {
          if (activeRegion || activeCountry) {
            activeFilterLabel.textContent = activeRegion || activeCountry;
            activeFilterCount.textContent = String(visibleCount);
            activeFilterBar.style.display = 'flex';
          } else {
            activeFilterBar.style.display = 'none';
          }
        }
      }

      function toggleFilter(region, country) {
        if (region) {
          activeRegion = activeRegion === region ? null : region;
          activeCountry = null;
        } else if (country) {
          activeCountry = activeCountry === country ? null : country;
          activeRegion = null;
        }
        
        syncActiveStates();
        filterCatalog();
      }

      function syncActiveStates() {
        // Clear all active classes
        hotspots.forEach(h => h.classList.remove('active'));
        mapRegions.forEach(r => r.classList.remove('active'));

        if (activeRegion) {
          const activeH = document.querySelector(`.hotspot[data-filter-region="${activeRegion}"]`);
          const activeR = document.querySelector(`.map-region-path[data-filter-region="${activeRegion}"]`);
          if (activeH) activeH.classList.add('active');
          if (activeR) activeR.classList.add('active');
        } else if (activeCountry) {
          const activeH = document.querySelector(`.hotspot[data-filter-country="${activeCountry}"]`);
          const activeC = document.querySelector(`.map-country-group[data-filter-country="${activeCountry}"]`);
          if (activeH) activeH.classList.add('active');
          if (activeC) activeC.classList.add('active');
        }
      }

      // Add bidirectional hover linkage
      function addHoverLinkage(el, type, value) {
        el.addEventListener('mouseenter', () => {
          if (type === 'region') {
            const matches = document.querySelectorAll(`.hotspot[data-filter-region="${value}"], .map-region-path[data-filter-region="${value}"]`);
            matches.forEach(m => { if (m !== el) m.classList.add('hover'); });
          } else {
            const matches = document.querySelectorAll(`.hotspot[data-filter-country="${value}"], .map-country-group[data-filter-country="${value}"]`);
            matches.forEach(m => { if (m !== el) m.classList.add('hover'); });
          }
        });
        el.addEventListener('mouseleave', () => {
          if (type === 'region') {
            const matches = document.querySelectorAll(`.hotspot[data-filter-region="${value}"], .map-region-path[data-filter-region="${value}"]`);
            matches.forEach(m => { if (m !== el) m.classList.remove('hover'); });
          } else {
            const matches = document.querySelectorAll(`.hotspot[data-filter-country="${value}"], .map-country-group[data-filter-country="${value}"]`);
            matches.forEach(m => { if (m !== el) m.classList.remove('hover'); });
          }
        });
      }

      // Bind SVG elements
      mapRegions.forEach(el => {
        const region = el.getAttribute('data-filter-region');
        const country = el.getAttribute('data-filter-country');
        
        if (region) addHoverLinkage(el, 'region', region);
        if (country) addHoverLinkage(el, 'country', country);
        
        el.addEventListener('click', (e) => {
          e.stopPropagation();
          toggleFilter(region, country);
        });
      });

      // Bind Hotspots
      hotspots.forEach(el => {
        const region = el.getAttribute('data-filter-region');
        const country = el.getAttribute('data-filter-country');
        
        if (region) addHoverLinkage(el, 'region', region);
        if (country) addHoverLinkage(el, 'country', country);
        
        el.addEventListener('click', (e) => {
          e.stopPropagation();
          toggleFilter(region, country);
        });
      });

      function handleReset() {
        activeRegion = null;
        activeCountry = null;
        hotspots.forEach(h => h.classList.remove('active'));
        mapRegions.forEach(r => r.classList.remove('active'));
        filterCatalog();
      }

      if (clearFilterBtn) {
        clearFilterBtn.addEventListener('click', handleReset);
      }

      // Initialize "Read More" buttons for overflow descriptions
      function initReadMore() {
        const descriptions = document.querySelectorAll('.wine-description');
        descriptions.forEach(desc => {
          // Check if scrollHeight is larger than clientHeight (overflow detection under Webkit line clamp)
          if (desc.scrollHeight > desc.clientHeight) {
            const button = document.createElement('button');
            button.className = 'read-more-btn';
            button.textContent = 'Read More';
            
            // Insert after the description element
            desc.parentNode.insertBefore(button, desc.nextSibling);
            
            button.addEventListener('click', (e) => {
              e.preventDefault();
              const isExpanded = desc.classList.toggle('expanded');
              if (isExpanded) {
                button.textContent = 'Read Less';
              } else {
                button.textContent = 'Read More';
                // Scroll the card back into view smoothly if collapsed
                desc.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
              }
            });
          }
        });
      }

      // Run on DOM load
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initReadMore);
      } else {
        initReadMore();
      }
    </script>
  </body>
</html>

