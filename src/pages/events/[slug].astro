---
import { createDirectus, rest, readItems } from '@directus/sdk';

export async function getStaticPaths() {
  const client = createDirectus('https://cms.estellawine.com').with(rest());
  try {
    const events = await client.request(
      readItems('estella_events', {
        filter: {
          status: {
            _eq: 'published'
          }
        }
      })
    );
    return events.map((event) => ({
      params: { slug: event.slug },
      props: { event }
    }));
  } catch (e) {
    console.error('Error fetching static paths for events:', e);
    return [];
  }
}

const { event } = Astro.props;

function formatDate(dateStr) {
  if (!dateStr) return '';
  const date = new Date(dateStr);
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
}

// Process description to rewrite relative Directus asset paths to absolute URLs
const processedDescription = event.description
  ? event.description.replace(/src="\/assets\//g, 'src="https://cms.estellawine.com/assets/')
  : '';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{event.title} — Estella Wine</title>
    
    <!-- Premium Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Dancing+Script:wght@400;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <!-- Sidebar Navigation Drawer -->
    <div class="sidebar-overlay" id="sidebarOverlay"></div>
    <div class="sidebar-drawer" id="sidebarDrawer">
      <button class="sidebar-close" id="sidebarCloseBtn" aria-label="Close menu">&times;</button>
      <div class="sidebar-logo">
        <img src="/estellawine_logo.png" alt="Estella Wine Logo" class="logo-image" />
      </div>
      <nav class="sidebar-links">
        <a href="/" class="sidebar-link">Our Story</a>
        <a href="/our-wines" class="sidebar-link">Our Wines</a>
        <a href="/where-find-our-wines" class="sidebar-link">Where to Find Us</a>
        <a href="/events" class="sidebar-link active">Events</a>
        <a href="/contact-us" class="sidebar-link">Contact Us</a>
      </nav>
      <div class="sidebar-socials">
        <a href="https://www.instagram.com/estellawine" target="_blank" rel="noopener noreferrer" class="social-link sidebar-social" aria-label="Instagram">
          <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
          </svg>
        </a>
        <a href="https://www.facebook.com/estellawine" target="_blank" rel="noopener noreferrer" class="social-link sidebar-social" aria-label="Facebook">
          <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
          </svg>
        </a>
      </div>
    </div>

    <header class="navbar">
      <div class="container navbar-top">
        <button class="hamburger-btn" id="hamburgerMenuBtn" aria-label="Open navigation menu">
          <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
            <line x1="3" y1="12" x2="21" y2="12"></line>
            <line x1="3" y1="6" x2="21" y2="6"></line>
            <line x1="3" y1="18" x2="21" y2="18"></line>
          </svg>
        </button>

        <a href="/" class="brand-logo">
          <img src="/estellawine_logo.png" alt="Estella Wine Logo" class="logo-image" />
        </a>

        <div class="navbar-right">
          <a href="https://www.instagram.com/estellawine" target="_blank" rel="noopener noreferrer" class="social-link header-social" aria-label="Instagram">
            <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
            </svg>
          </a>
          <a href="https://www.facebook.com/estellawine" target="_blank" rel="noopener noreferrer" class="social-link header-social" aria-label="Facebook">
            <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
            </svg>
          </a>
        </div>
      </div>
    </header>

    <div class="navbar-bottom">
      <nav class="nav-links">
        <a href="/" class="nav-link">Our Story</a>
        <a href="/our-wines" class="nav-link">Our Wines</a>
        <a href="/where-find-our-wines" class="nav-link">Where to Find Us</a>
        <a href="/events" class="nav-link active">Events</a>
        <a href="/contact-us" class="nav-link">Contact Us</a>
      </nav>
    </div>

    <main class="main-content">
      <div class="container small-container">
        <!-- Back Navigation -->
        <a href="/events" class="back-link">
          <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
          </svg>
          Back to Events
        </a>

        <!-- Event Details Card -->
        <article class="event-details-wrapper">
          {event.image && (
            <div class="event-hero-image-wrapper">
              <img 
                src={`https://cms.estellawine.com/assets/${event.image}`} 
                alt={event.title} 
                class="event-hero-image"
              />
            </div>
          )}

          <div class="event-meta">
            {event.event_date && (
              <span class="event-date">{formatDate(event.event_date)}</span>
            )}
          </div>

          <h1 class="event-title">{event.title}</h1>
          <div class="title-divider"></div>

          <div class="event-body-content" set:html={processedDescription}></div>
        </article>
      </div>
    </main>

    <footer class="footer">
      <div class="container text-center">
        <p class="footer-tagline">Fine Wine Company</p>
        <p>&copy; {new Date().getFullYear()} Estella Wine. All rights reserved.</p>
      </div>
    </footer>

    <script>
      const hamburgerBtn = document.getElementById('hamburgerMenuBtn');
      const sidebarCloseBtn = document.getElementById('sidebarCloseBtn');
      const sidebarDrawer = document.getElementById('sidebarDrawer');
      const sidebarOverlay = document.getElementById('sidebarOverlay');
      const navbar = document.querySelector('.navbar');

      function openSidebar() {
        if (sidebarDrawer && sidebarOverlay) {
          sidebarDrawer.classList.add('open');
          sidebarOverlay.classList.add('visible');
          document.body.style.overflow = 'hidden';
        }
      }

      function closeSidebar() {
        if (sidebarDrawer && sidebarOverlay) {
          sidebarDrawer.classList.remove('open');
          sidebarOverlay.classList.remove('visible');
          document.body.style.overflow = '';
        }
      }

      if (hamburgerBtn && sidebarCloseBtn && sidebarOverlay) {
        hamburgerBtn.addEventListener('click', openSidebar);
        sidebarCloseBtn.addEventListener('click', closeSidebar);
        sidebarOverlay.addEventListener('click', closeSidebar);
      }

      function handleScroll() {
        if (navbar) {
          if (window.scrollY > 20) {
            navbar.classList.add('scrolled');
          } else {
            navbar.classList.remove('scrolled');
          }
        }
      }

      window.addEventListener('scroll', handleScroll);
      handleScroll();
    </script>
  </body>
</html>

<style is:global>
  html {
    scrollbar-gutter: stable;
  }
  /* Premium Day Theme variables */
  :root {
    --bg-dark: #f8f8fa;
    --bg-surface: rgba(255, 255, 255, 0.9);
    --bg-surface-hover: rgba(255, 255, 255, 1);
    --border-color: rgba(197, 168, 128, 0.25);
    
    --text-primary: #1c1b1f;
    --text-secondary: #4e4b52;
    --text-muted: #7a7680;
    
    --color-gold: #9b7c56;
    --color-gold-hover: #b8966c;
    --color-burgundy: #800020;
    
    --transition-smooth: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Reset */
  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    background-image: url('/carrara_marble.jpg');
    background-repeat: repeat;
    background-color: var(--bg-dark);
    color: var(--text-primary);
    font-family: 'Outfit', sans-serif;
    line-height: 1.8;
    -webkit-font-smoothing: antialiased;
  }

  h1, h2, h3, h4, .brand-logo {
    font-family: 'Playfair Display', serif;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .small-container {
    max-width: 800px;
  }

  .text-center {
    text-align: center;
  }

  /* Navbar styling */
  .navbar {
    position: sticky;
    top: 0;
    z-index: 100;
    padding: 20px 0 10px 0;
    background-color: transparent;
    transition: background-color 0.3s ease, padding 0.3s ease, border-bottom 0.3s ease, box-shadow 0.3s ease;
  }

  .navbar.scrolled {
    background-color: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border-color);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
    padding: 10px 0;
  }

  .navbar-top {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
  }

  .brand-logo {
    color: var(--text-primary);
    text-decoration: none;
    display: flex;
    align-items: center;
  }

  .logo-image {
    height: 32px;
    width: auto;
    display: block;
    transition: height 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .navbar.scrolled .logo-image {
    height: 26px;
  }

  @media (max-width: 768px) {
    .logo-image {
      height: 24px;
    }
    .navbar.scrolled .logo-image {
      height: 22px;
    }
  }

  .hamburger-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--text-primary);
    padding: 10px;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: var(--transition-smooth);
  }

  .hamburger-btn:hover {
    color: var(--color-gold);
  }

  .navbar-right {
    justify-self: end;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .social-link {
    color: var(--text-primary);
    transition: var(--transition-smooth);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
  }

  .social-link:hover {
    color: var(--color-gold);
    background-color: rgba(155, 124, 86, 0.05);
  }

  @media (max-width: 768px) {
    .header-social {
      display: none;
    }
  }

  .navbar-bottom {
    display: flex;
    justify-content: center;
    margin-top: 15px;
    margin-bottom: 5px;
  }

  .nav-links {
    display: flex;
    gap: 32px;
  }

  .nav-link {
    color: var(--text-secondary);
    text-decoration: none;
    font-weight: 500;
    font-size: 15px;
    letter-spacing: 1px;
    text-transform: uppercase;
    transition: var(--transition-smooth);
    padding-bottom: 4px;
    border-bottom: 2px solid transparent;
  }

  .nav-link:hover, .nav-link.active {
    color: var(--color-gold);
    border-bottom-color: var(--color-gold);
  }

  /* Sidebar Navigation Drawer */
  .sidebar-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background-color: rgba(0, 0, 0, 0.3);
    backdrop-filter: blur(4px);
    z-index: 1000;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .sidebar-overlay.visible {
    opacity: 1;
    pointer-events: auto;
  }

  .sidebar-drawer {
    position: fixed;
    top: 0;
    left: 0;
    width: 300px;
    height: 100vh;
    background-color: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(16px);
    border-right: 1px solid var(--border-color);
    box-shadow: 4px 0 30px rgba(0, 0, 0, 0.05);
    z-index: 1001;
    transform: translateX(-100%);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    flex-direction: column;
    padding: 40px 30px;
  }

  .sidebar-drawer.open {
    transform: translateX(0);
  }

  .sidebar-close {
    position: absolute;
    top: 20px;
    right: 20px;
    background: none;
    border: none;
    font-size: 28px;
    cursor: pointer;
    color: var(--text-secondary);
    transition: var(--transition-smooth);
  }

  .sidebar-close:hover {
    color: var(--color-gold);
  }

  .sidebar-logo {
    margin-top: 20px;
    margin-bottom: 40px;
    display: flex;
    justify-content: center;
  }

  .sidebar-logo .logo-image {
    width: 100%;
    max-width: 100%;
    height: auto;
  }

  .sidebar-links {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .sidebar-link {
    color: var(--text-primary);
    text-decoration: none;
    font-weight: 500;
    font-size: 18px;
    letter-spacing: 1px;
    text-transform: uppercase;
    transition: var(--transition-smooth);
    padding-left: 5px;
    border-left: 2px solid transparent;
  }

  .sidebar-link:hover, .sidebar-link.active {
    color: var(--color-gold);
    border-left-color: var(--color-gold);
    padding-left: 10px;
  }

  .sidebar-socials {
    margin-top: auto;
    display: flex;
    gap: 15px;
    justify-content: center;
  }

  /* Page Content */
  .main-content {
    padding: 80px 0 100px;
    min-height: calc(100vh - 280px);
  }

  /* Back Link */
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--color-gold);
    text-decoration: none;
    font-weight: 600;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 30px;
    transition: var(--transition-smooth);
  }

  .back-link:hover {
    color: var(--color-burgundy);
  }

  .back-link svg {
    transition: transform 0.3s ease;
  }

  .back-link:hover svg {
    transform: translateX(-5px);
  }

  /* Event Details Card */
  .event-details-wrapper {
    background-color: var(--bg-surface);
    border: 1px solid var(--border-color);
    border-radius: 16px;
    padding: 40px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.03);
  }

  @media (max-width: 768px) {
    .event-details-wrapper {
      padding: 24px;
    }
  }

  .event-hero-image-wrapper {
    width: 100%;
    max-height: 450px;
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 30px;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.05);
  }

  .event-hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .event-meta {
    margin-bottom: 12px;
  }

  .event-date {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-burgundy);
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .event-title {
    font-size: 38px;
    font-weight: 500;
    color: var(--text-primary);
    line-height: 1.3;
    margin-bottom: 20px;
  }

  .title-divider {
    width: 80px;
    height: 2px;
    background-color: var(--color-gold);
    margin-bottom: 30px;
  }

  /* WYSIWYG Content styling */
  .event-body-content {
    font-size: 17px;
    color: var(--text-secondary);
    line-height: 1.8;
  }

  .event-body-content p {
    margin-bottom: 24px;
  }

  .event-body-content h2, 
  .event-body-content h3 {
    font-family: 'Playfair Display', serif;
    color: var(--text-primary);
    margin-top: 40px;
    margin-bottom: 16px;
    font-weight: 500;
  }

  .event-body-content h2 { font-size: 28px; }
  .event-body-content h3 { font-size: 22px; }

  .event-body-content ul, 
  .event-body-content ol {
    margin-bottom: 24px;
    padding-left: 24px;
  }

  .event-body-content li {
    margin-bottom: 8px;
  }

  .event-body-content img {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 30px 0;
    box-shadow: 0 6px 20px rgba(0,0,0,0.04);
  }

  .event-body-content a {
    color: var(--color-burgundy);
    text-decoration: underline;
    transition: var(--transition-smooth);
  }

  .event-body-content a:hover {
    color: var(--color-gold);
  }

  /* Footer */
  .footer {
    border-top: 1px solid var(--border-color);
    background-color: var(--bg-surface);
    padding: 40px 0;
    margin-top: auto;
  }

  .footer-tagline {
    font-family: 'Playfair Display', serif;
    font-size: 20px;
    font-style: italic;
    color: var(--color-gold);
    margin-bottom: 10px;
  }

  .footer p {
    color: var(--text-muted);
    font-size: 14px;
  }
</style>
