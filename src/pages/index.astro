        <!-- Hamburger Menu Icon on Left -->
        <button class="hamburger-btn" id="hamburgerMenuBtn" aria-label="Open navigation menu">
          <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
            <line x1="3" y1="12" x2="21" y2="12"></line>
            <line x1="3" y1="6" x2="21" y2="6"></line>
            <line x1="3" y1="18" x2="21" y2="18"></line>
          </svg>
        </button>

        <!-- Centered Logo -->
        <a href="/" class="brand-logo">
          <img src="/estellawine_logo.png" alt="Estella Wine Logo" class="logo-image" />
        </a>

        <!-- Right Side Social Icons (Desktop) / Spacer (Mobile) -->
        <div class="navbar-right">
          <a href="https://www.instagram.com/estellawine" target="_blank" rel="noopener noreferrer" class="social-link header-social" aria-label="Instagram">
            <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
            </svg>
          </a>
          <a href="https://www.facebook.com/estellawine" target="_blank" rel="noopener noreferrer" class="social-link header-social" aria-label="Facebook">
            <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
            </svg>
          </a>
        </div>
      </div>
    </header>

    <div class="navbar-bottom">
      <nav class="nav-links">
        <a href="/" class="nav-link active">Our Story</a>
        <a href="/our-wines" class="nav-link">Our Wines</a>
        <a href="/where-find-our-wines" class="nav-link">Where to Find Us</a>
        <a href="/events" class="nav-link">Events</a>
        <a href="/contact-us" class="nav-link">Contact Us</a>
      </nav>
    </div>

    <main class="main-content">
      <div class="container">
        <div class="story-wrapper">
          <!-- Hero Cellar Banner / Event Promo -->
          {featuredEvent && featuredEvent.image ? (
            <div class="story-hero-promo" style={`--promo-bg-url: url('https://cms.estellawine.com/assets/${featuredEvent.image}')`}>
              <div class="promo-blur-bg"></div>
              <div class="promo-card">
                <a href={`/events/${featuredEvent.slug}`} aria-label={`View details for event: ${featuredEvent.title}`}>
                  <img src={`https://cms.estellawine.com/assets/${featuredEvent.image}`} alt={featuredEvent.title} class="promo-image" />
                </a>
              </div>
            </div>
          ) : (
            <div class="story-hero-banner">
              <img src="/estella_story_hero.jpg" alt="Estella Wine Cellar" class="story-hero-image" />
              <div class="story-hero-overlay"></div>
            </div>
          )}

          <!-- Intro Section (centered typography) -->
          <div class="story-intro-container">
            <span class="subtitle">Heritage & Passion</span>
            <h1 class="story-title">Our Story</h1>
            <div class="story-divider"></div>
            <p class="story-intro-text">
              Established in August 2014 by a group of experienced wine enthusiasts, Estella Wine has grown to become one of Thailand’s premier fine wine importers and distributors.
            </p>
          </div>

          <!-- Three Pillars Grid -->
          <div class="story-pillars-grid">
            <div class="pillar-card">
              <span class="pillar-number">01</span>
              <h3 class="pillar-title">Boutique Selection</h3>
              <p class="pillar-text">We select top-quality wines from boutique and finest vineyards, curating only the most exceptional bottles for our catalog.</p>
            </div>
            <div class="pillar-card">
              <span class="pillar-number">02</span>
              <h3 class="pillar-title">Cold Chain Logistics</h3>
              <p class="pillar-text">All wines are imported directly from the estates using 100% temperature-controlled containers to guarantee freshness.</p>
            </div>
            <div class="pillar-card">
              <span class="pillar-number">03</span>
              <h3 class="pillar-title">A Curator's Promise</h3>
              <p class="pillar-text">We are a passionate team dedicated to delivering an unmatched fine wine discovery experience in Thailand.</p>
            </div>
          </div>

          <!-- Call to Action -->
          <div class="story-cta">
            <a href="/our-wines" class="btn btn-primary">Explore Our Wine Collection</a>
          </div>

          <!-- Latest Events Section -->
          {events && events.length > 0 && (
            <div class="story-events-section">
              <div class="text-center section-header">
                <span class="subtitle">News & Gatherings</span>
                <h2 class="story-title text-center">Latest Events</h2>
                <div class="story-divider"></div>
              </div>
              
              <div class="story-events-grid">
                {events.map((event) => (
                  <article class="home-event-card">
                    <a href={`/events/${event.slug}`} class="home-event-img-link">
                      <div class="home-event-img-wrapper">
                        {event.image ? (
                          <img src={`https://cms.estellawine.com/assets/${event.image}`} alt={event.title} class="home-event-img" />
                        ) : (
                          <div class="home-event-placeholder"><span>Estella</span></div>
                        )}
                      </div>
                    </a>
                    <div class="home-event-body">
                      <h3 class="home-event-card-title">
                        <a href={`/events/${event.slug}`}>{event.title}</a>
                      </h3>
                      <a href={`/events/${event.slug}`} class="home-event-more">Read More &rarr;</a>
                    </div>
                  </article>
                ))}
              </div>
              <div class="text-center events-viewall">
                <a href="/events" class="btn btn-secondary">View All Events</a>
              </div>
            </div>
          )}

          <!-- Founder's Signature Quote Box -->
          <div class="story-founder-container">
            <div class="founder-quote-card">
              <span class="quote-mark">“</span>
              <p class="quote-text">We hope you will enjoy our fine wine selections and offers!</p>
              <div class="founder-signature-block">
                <span class="founder-name">Ronavish Chulajata</span>
                <span class="founder-role">Founder, Estella Company Limited</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>

    <footer class="footer">
      <div class="container text-center">
        <p class="footer-tagline">Fine Wine Company</p>
        <p>&copy; {new Date().getFullYear()} Estella Wine. All rights reserved.</p>
      </div>
    </footer>

    <script>
      const hamburgerBtn = document.getElementById('hamburgerMenuBtn');
      const sidebarCloseBtn = document.getElementById('sidebarCloseBtn');
      const sidebarDrawer = document.getElementById('sidebarDrawer');
      const sidebarOverlay = document.getElementById('sidebarOverlay');
      const navbar = document.querySelector('.navbar');

      function openSidebar() {
        if (sidebarDrawer && sidebarOverlay) {
          sidebarDrawer.classList.add('open');
          sidebarOverlay.classList.add('visible');
          document.body.style.overflow = 'hidden';
        }
      }

      function closeSidebar() {
        if (sidebarDrawer && sidebarOverlay) {
          sidebarDrawer.classList.remove('open');
          sidebarOverlay.classList.remove('visible');
          document.body.style.overflow = '';
        }
      }

      if (hamburgerBtn && sidebarCloseBtn && sidebarOverlay) {
        hamburgerBtn.addEventListener('click', openSidebar);
        sidebarCloseBtn.addEventListener('click', closeSidebar);
        sidebarOverlay.addEventListener('click', closeSidebar);
      }

      function handleScroll() {
        if (navbar) {
          if (window.scrollY > 20) {
            navbar.classList.add('scrolled');
          } else {
            navbar.classList.remove('scrolled');
          }
        }
      }

      window.addEventListener('scroll', handleScroll);
      // Run once on load to set initial state
      handleScroll();
    </script>
  </body>
</html>

<style is:global>
  html {
    scrollbar-gutter: stable;
  }
  /* Premium Day Theme variables */
  :root {
    --bg-dark: #f8f8fa;
    --bg-surface: rgba(255, 255, 255, 0.9);
    --bg-surface-hover: rgba(255, 255, 255, 1);
    --border-color: rgba(197, 168, 128, 0.25);
    
    --text-primary: #1c1b1f;
    --text-secondary: #4e4b52;
    --text-muted: #7a7680;
    
    --color-gold: #9b7c56;
    --color-gold-hover: #b8966c;
    --color-burgundy: #800020;
    
    --transition-smooth: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Reset */
  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    background-image: url('/carrara_marble.jpg');
