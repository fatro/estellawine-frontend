    border-bottom-color: var(--color-gold);
  }

  /* Sidebar Navigation Drawer */
  .sidebar-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background-color: rgba(0, 0, 0, 0.3);
    backdrop-filter: blur(4px);
    z-index: 1000;
    opacity: 0;
