    width: 60px;
    height: 2px;
    background-color: var(--color-gold);
    margin: 0 auto;
  }

  .story-intro-text {
    font-size: 18px;
    color: var(--text-secondary);
    line-height: 1.8;
    max-width: 700px;
    margin: 30px auto 0 auto;
    font-weight: 300;
