---
import { createDirectus, rest, readItems } from '@directus/sdk';

// Initialize Directus SDK client
const client = createDirectus('https://cms.estellawine.com').with(rest());

let events = [];
let featuredEvent = null;
try {
  events = await client.request(
    readItems('estella_events', {
      sort: ['-event_date'],
      limit: 3,
      filter: {
        status: {
          _eq: 'published'
        }
      }
    })
  );

  // Fetch featured event for homepage hero banner
  const featuredEvents = await client.request(
    readItems('estella_events', {
      filter: {
        status: { _eq: 'published' },
        event_date: { _gte: new Date().toISOString() },
        feature_on_homepage: { _eq: true }
      },
      limit: 1
    })
  );
  if (featuredEvents && featuredEvents.length > 0) {
    featuredEvent = featuredEvents[0];
  }
} catch (e) {
  console.error('Error fetching events or featured event for index.astro:', e);
}

function formatDate(dateStr) {
  if (!dateStr) return '';
  const date = new Date(dateStr);
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>Our Story — Estella Wine</title>
    
    <!-- Premium Google Fonts -->
