  }

  .sidebar-drawer.open {
    transform: translateX(0);
  }

  .sidebar-close {
    position: absolute;
    top: 20px;
    right: 20px;
    background: none;
    border: none;
    font-size: 28px;
    cursor: pointer;
    color: var(--text-secondary);
    transition: var(--transition-smooth);
  }

  .sidebar-close:hover {
    color: var(--color-gold);
  }

  .sidebar-logo {
    margin-top: 20px;
    margin-bottom: 40px;
    display: flex;
    justify-content: center;
  }

  .sidebar-logo .logo-image {
    max-height: none;
    width: 100%;
    max-width: 100%;
    height: auto;
  }

  .sidebar-links {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .sidebar-link {
    color: var(--text-primary);
    text-decoration: none;
    font-size: 16px;
    font-weight: 500;
    letter-spacing: 1px;
    text-transform: uppercase;
    transition: var(--transition-smooth);
    padding: 10px 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.05);
  }

  .sidebar-link:hover, .sidebar-link.active {
    color: var(--color-gold);
    border-bottom-color: var(--color-gold);
  }

  .sidebar-socials {
    margin-top: auto;
    display: flex;
    justify-content: center;
    gap: 16px;
    padding-top: 20px;
    border-top: 1px solid var(--border-color);
  }

  /* Main Content Layout */
  .main-content {
    padding: 80px 0 100px;
    min-height: calc(100vh - 280px);
  }

  /* Story/About Article layout */
  .story-wrapper {
    margin-top: 0;
    margin-bottom: 80px;
  }

  .story-hero-banner {
    position: relative;
    width: 100%;
    height: 480px;
    border-radius: 16px;
    overflow: hidden;
    margin-bottom: 60px;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
  }

  .story-hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .story-hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(180deg, rgba(26, 19, 13, 0.1) 0%, rgba(26, 19, 13, 0.5) 100%);
  }

  .story-hero-promo {
    position: relative;
    width: 100%;
    height: 480px;
    border-radius: 16px;
    overflow: hidden;
    margin-bottom: 60px;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
    display: flex;
    justify-content: center;
    align-items: center;
    background-color: #0c0b0c;
  }

  .promo-blur-bg {
    position: absolute;
    inset: -30px;
    background-image: var(--promo-bg-url);
    background-size: cover;
    background-position: center;
    filter: blur(60px) brightness(0.45);
    z-index: 1;
  }

  .promo-card {
    position: relative;
    z-index: 2;
    width: 90%;
    max-width: 650px;
    aspect-ratio: 5 / 3;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    border-radius: 8px;
    overflow: hidden;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.3s ease;
  }

  .promo-card:hover {
    transform: scale(1.025);
    box-shadow: 0 35px 65px rgba(0, 0, 0, 0.6);
  }

  .promo-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    cursor: pointer;
  }

  @media (max-width: 768px) {
    .story-hero-promo {
      height: auto;
      aspect-ratio: 5 / 3;
      margin-bottom: 40px;
      border-radius: 12px;
    }
    
    .promo-card {
      width: 100%;
      max-width: none;
      border-radius: 12px;
      box-shadow: none;
    }
  }

  .story-intro-container {
    max-width: 800px;
    margin: 0 auto 60px auto;
    text-align: center;
  }

  .subtitle {
    color: var(--color-gold);
    text-transform: uppercase;
    letter-spacing: 3px;
    font-size: 12px;
    font-weight: 600;
    display: block;
    margin-bottom: 16px;
    text-align: center;
  }

  .story-title {
    font-size: 34px;
    font-weight: 300;
    line-height: 1.45;
    color: var(--text-primary);
    margin-top: 10px;
    margin-bottom: 24px;
    font-family: 'Playfair Display', serif;
